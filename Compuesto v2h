local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- [ VARIABLES HITBOX ]
local active = false
local range = 10 -- Tamaño inicial por defecto
local showPart = true
local targetText = ""

-- Variables para evitar spam de notificaciones
local lastNotifiedSize = 10
local lastNotifiedTarget = ""

-- --- LÓGICA DE LIMPIEZA ---
local function resetHead(player)
    if player and player.Character and player.Character:FindFirstChild("Head") then
        local head = player.Character.Head
        -- Tamaño estándar para no deformar al jugador al desactivar
        head.Size = Vector3.new(1.2, 1.2, 1.2) 
        head.Transparency = 0
        head.CanCollide = true
        head.Massless = false
    end
end

local function resetAll()
    for _, v in pairs(Players:GetPlayers()) do 
        if v ~= LocalPlayer then
            resetHead(v) 
        end
    end
end

-- [ INTERFAZ WINDUI ]
local W = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()

local w = W:CreateWindow({
    Title = "☢️ Family HS HUB",
    Author = "by jake_Hs",
    Folder = "HsHub",
    Accent = Color3.fromRGB(255, 255, 0),
    Transparent = true,
    Theme = "Dark",
    Size = UDim2.fromOffset(580, 460),
    Resizable = true,
    OpenButton = {
        Title = "hitbox Head",
        CornerRadius = UDim.new(1, 0),
        StrokeThickness = 2,
        Enabled = true,
        Draggable = true,
        Scale = 0.8,
        Color = ColorSequence.new(Color3.fromHex("#FFFF00"), Color3.fromHex("#FFA500"))
    }
})

-- --- PESTAÑA: HITBOX ---
local hT = w:Tab({ Title = "Hitbox", Icon = "solar:target-bold" })

hT:Toggle({
    Title = "Activar Hitbox",
    Desc = "También puedes usar la tecla [Y] para encender/apagar.",
    Value = active,
    Callback = function(state)
        active = state
        if not active then resetAll() end
    end
})

hT:Toggle({
    Title = "Cubo Visible",
    Value = showPart,
    Callback = function(state)
        showPart = state
        if active then resetAll() end
    end
})

-- [ CAJA DE TEXTO PARA EL TAMAÑO CON NOTIFICACIÓN ]
hT:Input({
    Title = "Tamaño del Hitbox",
    PlaceholderText = "Escribe un número (Ej: 15)",
    Callback = function(text)
        local num = tonumber(text)
        if num and num ~= lastNotifiedSize then
            range = num
            lastNotifiedSize = num
            
            W:Notify({
                Title = "⚙️ Tamaño Actualizado",
                Content = "Nuevo tamaño de hitbox asignado: " .. tostring(num),
                Duration = 5
            })
        end
    end
})

-- [ CAJA DE TEXTO PARA TARGET CON NOTIFICACIÓN ]
hT:Input({
    Title = "Filtro de Jugadores",
    PlaceholderText = "Nombres separados por espacio (Ej: Juan Pedro)",
    Callback = function(text)
        if text ~= lastNotifiedTarget then
            targetText = text
            lastNotifiedTarget = text
            
            local mensaje = text == "" and "Filtro limpiado. Aplicando a todos." or "Objetivo(s) asignado(s): " .. text
            
            W:Notify({
                Title = "🎯 Objetivo Actualizado",
                Content = mensaje,
                Duration = 5
            })
        end
    end
})

-- --- PESTAÑA: AJUSTES ---
local sT = w:Tab({ Title = "Ajustes", Icon = "solar:settings-bold" })

sT:Button({
    Title = "🛑 Destruir Script",
    Desc = "Limpia las cabezas y cierra la interfaz.",
    Color = Color3.fromRGB(255, 50, 50),
    Callback = function()
        active = false
        resetAll()
        if w and w.Destroy then w:Destroy() end
    end
})

-- --- EVENTOS Y BUCLE PRINCIPAL ---

-- Keybind Tecla Y
UIS.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.Y then 
        active = not active
        if not active then resetAll() end
        
        W:Notify({
            Title = "Hitbox Head",
            Content = active and "✅ Activado con tecla Y" or "❌ Desactivado con tecla Y",
            Duration = 3
        })
    end
end)

-- Bucle RenderStepped
RunService.RenderStepped:Connect(function()
    if not active then return end
    
    local targets = {}
    if targetText and targetText ~= "" then
        for s in targetText:gmatch("%S+") do 
            table.insert(targets, s:lower()) 
        end
    end

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
            local head = v.Character.Head
            local isTargeted = false
            
            if #targets == 0 then
                isTargeted = true
            else
                for _, name in pairs(targets) do
                    if (v.Name and v.Name:lower():find(name)) or (v.DisplayName and v.DisplayName:lower():find(name)) then
                        isTargeted = true
                        break
                    end
                end
            end
            
            if isTargeted then
                head.Size = Vector3.new(range, range, range)
                head.Transparency = showPart and 0.5 or 1
                head.CanCollide = false
                head.Massless = true
            else
                head.Size = Vector3.new(1.2, 1.2, 1.2)
                head.Transparency = 0
            end
        end
    end
end)
