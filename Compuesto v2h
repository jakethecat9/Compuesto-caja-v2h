local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- [ VARIABLES HITBOX ]
local active = false
local range = 9 
local showPart = true
local targetText = ""

-- Variables para evitar spam de notificaciones
local lastNotifiedSize = 9
local lastNotifiedTarget = ""

-- Variables Movilidad
local tpWalk = false
local tpSpeed = 1
local infJump = false
local noClip = false

-- --- LÓGICA DE LIMPIEZA ---
local function resetHead(player)
    if player and player.Character and player.Character:FindFirstChild("Head") then
        local head = player.Character.Head
        head.Size = Vector3.new(1.2, 1.2, 1.2) 
        head.Transparency = 0
        head.CanCollide = true
        head.Massless = false
    end
end

local function resetAll()
    for _, v in pairs(Players:GetPlayers()) do 
        if v ~= LocalPlayer then
            resetHead(v) 
        end
    end
end

-- [ INTERFAZ WINDUI ]
local W = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()

local w = W:CreateWindow({
    Title = "☢️ Family HS HUB",
    Author = "by jake_Hs",
    Folder = "HsHub",
    Accent = Color3.fromRGB(255, 255, 0),
    Transparent = true,
    Theme = "Dark",
    Size = UDim2.fromOffset(580, 460),
    Resizable = true,
    OpenButton = {
        Title = "hitbox Head🗿 hs",
        CornerRadius = UDim.new(1, 0),
        StrokeThickness = 2,
        Enabled = true,
        Draggable = true,
        Scale = 0.8,
        Color = ColorSequence.new(Color3.fromHex("#FFFF00"), Color3.fromHex("#FFA500"))
    }
})

-- --- PESTAÑA: HITBOX ---
local hT = w:Tab({ Title = "Hitbox", Icon = "solar:target-bold" })

hT:Toggle({
    Title = "Activar Hitbox",
    Desc = "También puedes usar la tecla [Y] para encender/apagar.",
    Value = active,
    Callback = function(state)
        active = state
        if not active then resetAll() end
    end
})

hT:Toggle({
    Title = "Cubo Visible",
    Value = showPart,
    Callback = function(state)
        showPart = state
        if active then resetAll() end
    end
})

hT:Input({
    Title = "Tamaño del Hitbox",
    PlaceholderText = "Ej: 15 (Deja vacío para volver a 9)",
    Callback = function(text)
        if text == "" or text == " " then
            if lastNotifiedSize ~= 9 then
                range = 9
                lastNotifiedSize = 9
                W:Notify({ Title = "⚙️ Tamaño Restaurado", Content = "Se regresó al tamaño por defecto: 9", Duration = 5 })
            end
        else
            local num = tonumber(text)
            if num and num ~= lastNotifiedSize then
                range = num
                lastNotifiedSize = num
                W:Notify({ Title = "⚙️ Tamaño Actualizado", Content = "Nuevo tamaño asignado: " .. tostring(num), Duration = 5 })
            end
        end
    end
})

hT:Input({
    Title = "Filtro de Jugadores",
    PlaceholderText = "Iniciales o Nombres (Ej: Jua)",
    Callback = function(text)
        if text ~= lastNotifiedTarget then
            targetText = text
            lastNotifiedTarget = text
            
            if text == "" then
                W:Notify({ Title = "🎯 Objetivo Limpiado", Content = "Aplicando a todos los jugadores del servidor.", Duration = 5 })
            else
                local partials = {}
                for s in text:gmatch("%S+") do table.insert(partials, s:lower()) end
                local foundNames = {}
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer then
                        for _, part in pairs(partials) do
                            if (p.Name and p.Name:lower():find(part)) or (p.DisplayName and p.DisplayName:lower():find(part)) then
                                table.insert(foundNames, p.DisplayName .. " (@" .. p.Name .. ")")
                                break
                            end
                        end
                    end
                end
                
                if #foundNames > 0 then
                    W:Notify({ Title = "🎯 Objetivo Detectado", Content = "Asignado a: " .. table.concat(foundNames, ", "), Duration = 5 })
                else
                    W:Notify({ Title = "❌ Usuario no encontrado", Content = "No se halló ningún jugador que coincida con: " .. text, Duration = 5 })
                end
            end
        end
    end
})

-- --- PESTAÑA: MOVILIDAD ---
local mT = w:Tab({ Title = "Movilidad", Icon = "solar:run-bold" })
mT:Toggle({ Title = "TpWalk", Value = tpWalk, Callback = function(s) tpWalk = s end })
mT:Input({ Title = "Velocidad TpWalk", PlaceholderText = "1", Callback = function(t) tpSpeed = tonumber(t) or 1 end })
mT:Toggle({ Title = "Infinity Jump", Value = infJump, Callback = function(s) infJump = s end })
mT:Toggle({ Title = "Noclip", Value = noClip, Callback = function(s) noClip = s end })

-- --- PESTAÑA: AJUSTES ---
local sT = w:Tab({ Title = "Ajustes", Icon = "solar:settings-bold" })
sT:Button({
    Title = "🛑 Destruir Script",
    Desc = "Limpia las cabezas y cierra la interfaz.",
    Color = Color3.fromRGB(255, 50, 50),
    Callback = function()
        active = false
        tpWalk = false
        infJump = false
        noClip = false
        resetAll()
        if w and w.Destroy then w:Destroy() end
    end
})

-- --- EVENTOS Y BUCLE PRINCIPAL ---
UIS.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.Y then 
        active = not active
        if not active then resetAll() end
        W:Notify({ Title = "Hitbox Head", Content = active and "✅ Activado con tecla Y" or "❌ Desactivado con tecla Y", Duration = 3 })
    end
end)

UIS.JumpRequest:Connect(function()
    if infJump then LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping") end
end)

RunService.RenderStepped:Connect(function()
    -- Noclip
    if LocalPlayer.Character then
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = not noClip end
        end
    end

    -- TpWalk
    if tpWalk and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local moveDir = LocalPlayer.Character.Humanoid.MoveDirection
        if moveDir.Magnitude > 0 then hrp.CFrame = hrp.CFrame + (moveDir * tpSpeed) end
    end

    -- Hitbox
    if active then
        local targets = {}
        if targetText and targetText ~= "" then
            for s in targetText:gmatch("%S+") do table.insert(targets, s:lower()) end
        end
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
                local head = v.Character.Head
                local isTargeted = (#targets == 0)
                if not isTargeted then
                    for _, name in pairs(targets) do
                        if (v.Name and v.Name:lower():find(name)) or (v.DisplayName and v.DisplayName:lower():find(name)) then
                            isTargeted = true
                            break
                        end
                    end
                end
                if isTargeted then
                    head.Size = Vector3.new(range, range, range)
                    head.Transparency = showPart and 0.5 or 1
                    head.CanCollide = false
                    head.Massless = true
                else
                    head.Size = Vector3.new(1.2, 1.2, 1.2)
                    head.Transparency = 0
                end
            end
        end
    end
end)
